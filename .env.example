# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (email) — free up to 3,000/month at resend.com
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=hamelech@yourdomain.com

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://hamelech-amar.vercel.app

# Cron secret — set the same value in cron-job.org as Authorization header
CRON_SECRET=your_random_secret_here
